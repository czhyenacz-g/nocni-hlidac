# Discord OAuth login (viz TECH_DESIGN.md "Discord login") — jen identita
# hráče (login/logout/kdo je přihlášený), zatím žádný leaderboard, žádné
# ukládání výsledků, žádná DB. Bez těchto proměnných hra dál funguje beze
# změny (login jen tiše no-opne na "?auth=config_error"), jen jde bez configu
# hrát bez přihlášení, viz akceptační kritérium "hra jde spustit i bez loginu".

# Discord Developer Portal (https://discord.com/developers/applications) ->
# tvoje aplikace -> OAuth2 -> Client ID.
DISCORD_CLIENT_ID=

# Discord Developer Portal -> OAuth2 -> Client Secret. NIKDY nekomitovat
# skutečnou hodnotu, jen do lokálního/Vercel env.
DISCORD_CLIENT_SECRET=

# Musí PŘESNĚ odpovídat jednomu z "Redirects" v Discord Developer Portal ->
# OAuth2 -> Redirects, jinak Discord odmítne login s "Invalid OAuth2
# redirect_uri". Lokálně: http://localhost:3000/api/auth/callback
# Produkce: https://nocni-hlidac.vercel.app/api/auth/callback
DISCORD_REDIRECT_URI=

# Podepisuje session cookie (viz lib/auth/session.ts) — bez něj se
# přihlášení tiše neprovede (žádná nepodepsaná/padělatelná session). Vygeneruj
# např. `openssl rand -base64 32`.
AUTH_SECRET=

# Soukromé VPS API pro žebříček hlídačů (viz TECH_DESIGN.md "VPS API
# specifikace") — STEJNÝ princip jako osmaliga.cz -> project-hub-api: Vercel
# appka nemá přímé DB připojení, jen volá tenhle API, ten mluví s DB. Bez
# těchto proměnných /leaderboard spadne na mock data a survive-night/death
# volání se tiše no-opnou (202) — hra funguje beze změny (viz lib/hubClient.ts).
# Lokálně např. http://localhost:3001, produkce vlastní VPS doména.
NOCNI_HLIDAC_API_URL=

# Sdílený token posílaný jako `Authorization: Bearer <token>` (viz
# lib/hubClient.ts). NIKDY nekomitovat skutečnou hodnotu, jen do lokálního/
# Vercel env — VPS API strana musí mít stejnou hodnotu nastavenou u sebe.
NOCNI_HLIDAC_API_TOKEN=
